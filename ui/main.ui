         </widget>
        </item>
       </layout>
      </widget>

       <!-- ═══════════════ FACE RECOGNITION TAB ═══════════════ -->
       <widget class="QWidget" name="faceRecognitionTab">
        <attribute name="title"><string>Face Recognition</string></attribute>
        <layout class="QHBoxLayout">
         <item>
          <widget class="QWidget" name="faceRecLeftPanel">
           <property name="maximumWidth"><number>350</number></property>
           <layout class="QVBoxLayout">
            <item><widget class="QLabel" name="faceRecImageNameLbl"><property name="text"><string>No image loaded</string></property></widget></item>
