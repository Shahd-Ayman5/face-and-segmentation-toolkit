            <!-- Evaluation button -->
            <item><widget class="QPushButton" name="faceRecBtnEvaluate"><property name="text"><string>📊 Show Evaluation</string></property><property name="toolTip"><string>Run full test-set evaluation and show ROC curve, metrics and confusion matrix</string></property><property name="styleSheet"><string>background-color:#2a2060; color:#a5b4fc; border:1px solid #4a40a0; padding:6px; border-radius:4px;</string></property></widget></item>
            <item><spacer><property name="orientation"><enum>Qt::Vertical</enum></property></spacer></item>
