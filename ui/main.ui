        </item>

        <!-- RIGHT: Input + Output images side by side -->
        <item>
         <layout class="QHBoxLayout">
          <property name="spacing"><number>8</number></property>

          <!-- Input Image Frame (clickable for seeds) -->
          <item>
           <widget class="QFrame" name="segInputFrame">
            <property name="frameShape"><enum>QFrame::StyledPanel</enum></property>
            <property name="sizePolicy">
             <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
              <horstretch>1</horstretch><verstretch>1</verstretch>
             </sizepolicy>
            </property>
            <layout class="QVBoxLayout">
             <property name="margin"><number>4</number></property>
             <property name="spacing"><number>4</number></property>
             <item>
              <widget class="QLabel" name="segInputTitleLbl">
               <property name="text"><string>Input Image  (click to place seeds)</string></property>
               <property name="alignment"><set>Qt::AlignCenter</set></property>
               <property name="maximumHeight"><number>24</number></property>
               <property name="styleSheet"><string>font-weight: bold; font-size: 11pt; color: #ccc;</string></property>
