               <property name="margin"><number>4</number></property>
               <property name="spacing"><number>4</number></property>
               <item><widget class="QLabel" name="segOutputTitleLbl"><property name="text"><string>Output Image</string></property><property name="alignment"><set>Qt::AlignCenter</set></property><property name="maximumHeight"><number>24</number></property><property name="styleSheet"><string>font-weight:bold; font-size:11pt; color:#ccc;</string></property></widget></item>
               <item>
                <widget class="QLabel" name="segOutputCanvas">
